# Copy this file to .env.local and fill in the values you have.
# Nothing here is required to run the site locally — every form works in
# "demo mode" (logs to the server console) until these are set.

# --- Payments (src/app/api/checkout/route.ts) ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# --- Form notifications (src/app/api/quote/route.ts, src/app/api/contact/route.ts) ---
# Email: set one of these to enable email notifications for form submissions.
RESEND_API_KEY=
SMTP_HOST=
SMTP_USER=
SMTP_PASS=

# Spreadsheet logging: a webhook URL (e.g. a Google Apps Script Web App,
# Zapier, or Make.com webhook) that appends each submission to a sheet.
GOOGLE_SHEETS_WEBHOOK_URL=
