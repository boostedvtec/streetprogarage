# Copy this file to .env.local and fill in the values you have.
# Nothing here is required to run the site locally — every form works in
# "demo mode" (logs to the server console) until these are set.

# --- Chat widget (src/components/chat/tidio-widget.tsx) ---
# Sign up free at https://www.tidio.com, then Settings > Developer > Tidio
# Installation Code — copy the id from the script src (code.tidio.co/<id>.js).
# Without it, no chat widget is rendered.
NEXT_PUBLIC_TIDIO_PUBLIC_KEY=

# --- Payments (src/app/api/checkout/route.ts) ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# --- Form notifications (src/app/api/quote/route.ts, src/app/api/contact/route.ts) ---
# Email: set SMTP_HOST, SMTP_USER and SMTP_PASS to enable email notifications
# for form submissions (sent via src/lib/mailer.ts). For Gmail, use:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_USER=<your Gmail address>
#   SMTP_PASS=<a Google "App Password" — not your regular Gmail password>
SMTP_HOST=
SMTP_USER=
SMTP_PASS=
SMTP_PORT=587
# Optional overrides — default to info@streetprogarage.com if unset.
SMTP_FROM=
NOTIFY_EMAIL=

# RESEND_API_KEY is documented but not yet wired up — SMTP is the
# implemented path for now.
RESEND_API_KEY=

# Spreadsheet logging: a webhook URL (e.g. a Google Apps Script Web App,
# Zapier, or Make.com webhook) that appends each submission to a sheet.
GOOGLE_SHEETS_WEBHOOK_URL=
